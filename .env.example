# Port the HTTP server listens on (Railway sets this automatically — don't set manually)
PORT=3001

# WhatsApp group JID — find this by calling GET /groups after first deploy + QR scan
# Format: 120363XXXXXXXXXX@g.us
GROUP_JID=

# Shared secret — the Cloudflare Worker sends this to authenticate requests
# Generate with: openssl rand -hex 32
SERVICE_SECRET=change-me-to-something-secure

# Path where WhatsApp session files are stored
# Local:   auth_info   (relative path, fine for local dev)
# Railway: /app/auth_info  (must match the volume mount path in Railway dashboard)
AUTH_INFO_PATH=auth_info
